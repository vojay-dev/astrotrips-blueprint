{
  "description": "Configuration for the daily planet report generator.",
  "properties": {
    "conn_id": {
      "description": "Airflow connection ID for DuckDB",
      "title": "Conn Id",
      "type": "string"
    },
    "blueprint": {
      "type": "string",
      "const": "planet_report",
      "description": "The blueprint template to use"
    },
    "version": {
      "type": "integer",
      "const": 1,
      "description": "The blueprint version"
    }
  },
  "required": [
    "blueprint",
    "version",
    "conn_id"
  ],
  "title": "PlanetReport",
  "type": "object",
  "$schema": "http://json-schema.org/draft-07/schema#"
}